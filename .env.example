# VIKMO Auto-Parts Dealer Assistant — Environment Configuration Template
# Copy this file to .env and fill in your values.
# The assistant auto-loads .env on startup.

# ─── LLM Provider Selection ───────────────────────────────────────────────────
# Primary LLM provider. Options: ollama | gemini | groq | demo
LLM_PROVIDER=ollama

# Comma-separated fallback chain if primary fails (tried left to right)
FALLBACK_PROVIDERS=gemini,groq,demo

# ─── Ollama (Local, Keyless) ───────────────────────────────────────────────────
# Local Ollama service host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model name — must support tool calling (llama3.1 or newer)
# NOTE: legacy llama3 does NOT support tool calling and will return HTTP 400.
OLLAMA_MODEL=llama3.1

# ─── Google Gemini ─────────────────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Groq Cloud ────────────────────────────────────────────────────────────────
# Obtain from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Groq model name (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Demo Mode (Offline, Fully Local, No API Keys Required) ────────────────────
# Set to true to skip all LLM providers and run rule-based emulator locally
DEMO_MODE=false
