# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1102, it is recommended to not commit Pipfile.lock to version control.
#   However, in case of microservices or deployed applications, you should commit Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to commit poetry.lock in applications.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to commit pdm.lock in applications.
# pdm.lock

# venv
#   Virtual environments
.venv/
venv/
ENV/
env/
active_env/

